MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/kmdev?authSource=admin
NEXTAUTH_URL=https://your-vercel-app.vercel.app
NEXTAUTH_SECRET=replace-with-a-secure-random-string-at-least-32-characters
GITHUB_ID=
GITHUB_SECRET=
ADMIN_GITHUB_EMAIL=

# OpenRouter AI Chatbot (legacy)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=mistralai/mistral-7b-instruct-v0.1

# Dual-AI chatbot: Gemini (primary) + Grok (failover)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-flash-latest
GROK_API_KEY=your-grok-xai-api-key
GROK_MODEL=grok-2-latest
AI_GEMINI_ENABLED=true
AI_GROK_ENABLED=true